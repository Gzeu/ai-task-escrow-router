{
  "name": "@ai-task-escrow/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the AI Task Escrow Router protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@multiversx/sdk-core": "^13.10.0",
    "@multiversx/sdk-network-providers": "^2.6.0",
    "@multiversx/sdk-wallet": "^4.6.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist"
  ]
}