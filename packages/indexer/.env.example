# Network: devnet | testnet | mainnet
NETWORK=devnet

# Deployed contract address
CONTRACT_ADDRESS=erd1...

# MultiversX API endpoint
API_URL=https://devnet-api.multiversx.com

# MongoDB connection string
MONGODB_URL=mongodb://localhost:27017/ai-task-escrow

# Redis connection string (for caching/queuing)
REDIS_URL=redis://localhost:6379

# Indexer start block (leave empty to start from latest)
START_BLOCK=

# Port for the indexer HTTP server
PORT=3001
