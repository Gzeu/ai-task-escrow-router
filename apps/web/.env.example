# Network: devnet | testnet | mainnet
NEXT_PUBLIC_NETWORK=devnet

# Deployed contract address on the selected network
NEXT_PUBLIC_CONTRACT_ADDRESS=erd1...

# MultiversX API endpoint
NEXT_PUBLIC_API_URL=https://devnet-api.multiversx.com

# MultiversX gateway endpoint
NEXT_PUBLIC_GATEWAY_URL=https://devnet-gateway.multiversx.com

# Optional: WalletConnect project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
